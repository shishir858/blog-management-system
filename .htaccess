RewriteEngine On

# Match your install folder (empty if app is at domain root).
RewriteBase /blog-management-system/

# Public URL: /blog — redirect only real browser requests to blog.php (not internal rewrite from /blog → blog.php)
RewriteCond %{THE_REQUEST} \s[^\s]*blog\.php[\s?] [NC]
RewriteRule ^blog\.php$ blog [R=301,L,QSA]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SEO: friendly sitemap & robots URLs
RewriteRule ^sitemap\.xml$ sitemap.php [L]
RewriteRule ^page-sitemap\.xml$ page-sitemap.php [L]
RewriteRule ^post-sitemap\.xml$ post-sitemap.php [L]
RewriteRule ^robots\.txt$ robots.php [L]

# Blog listing: /blog (no .php)
RewriteRule ^blog/?$ blog.php [L,QSA]

# Pretty post URLs: /blog/{slug} → blog-detail.php
RewriteRule ^blog/([a-zA-Z0-9-]+)/?$ blog-detail.php?post=$1&from_rewrite=1 [L,QSA]
